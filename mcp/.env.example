# CloudNSofts MCP server configuration.
# The API base URL (no trailing slash).
CNSOFTS_API_URL=http://localhost:4000
# A Personal Access Token minted from the app: Settings → Connect coding agent.
CNSOFTS_TOKEN=cnsofts_pat_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Optional: set to 1 to register only read tools.
# CNSOFTS_READONLY=1
# Optional: set to 1 to also expose delete_task / delete_feature.
# CNSOFTS_ALLOW_DELETE=1
