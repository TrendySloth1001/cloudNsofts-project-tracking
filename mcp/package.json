{
  "name": "@cnsofts/mcp",
  "version": "0.1.0",
  "private": true,
  "description": "MCP server that lets a coding agent (e.g. Claude Code) drive CloudNSofts boards & discussions",
  "type": "module",
  "bin": {
    "cnsofts-mcp": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "files": [
    "dist"
  ],
  "scripts": {
