# Production backend env → copy to backend/.env on the server and fill secrets.
# The values here must line up with deploy.env (DB + MinIO credentials).
NODE_ENV=production
PORT=4000

# Postgres from compose.prod.yml (localhost:5432).
DATABASE_URL="postgresql://cloudnsofts:CHANGE_ME_strong_db_password@localhost:5432/cloudnsofts?schema=public"

# The public site — used for CORS and the Socket.IO handshake origin check.
CORS_ORIGIN=https://cloudnsofts.com

# Platform super-admin (reserved; not self-registerable).
ADMIN_EMAIL=you@cloudnsofts.com
ADMIN_PASSWORD=CHANGE_ME_strong_admin_password

# Token signing secret — generate with:  openssl rand -hex 32
AUTH_SECRET=CHANGE_ME_run_openssl_rand_hex_32
AUTH_TOKEN_TTL=7d

# API rate limit (per bearer token, else per IP).
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=300

# MinIO from compose.prod.yml (localhost:9000).
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=cloudnsofts
S3_SECRET_KEY=CHANGE_ME_strong_minio_password
S3_BUCKET=cnsofts-uploads

# Path to the bundled MCP server the app serves for download.
MCP_BUNDLE_PATH=agent-workspace/server/index.mjs
