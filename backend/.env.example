# Copy to .env. Postgres runs in Docker on host port 5434 (see docker-compose.yml).
# For many instances, cap the pool and/or run behind PgBouncer, e.g. append
# ?connection_limit=10&pool_timeout=20 to the URL.
DATABASE_URL="postgresql://cloudnsofts:cloudnsofts@localhost:5434/cloudnsofts_dev?schema=public"

# Port the API listens on
PORT=4000

# Allowed CORS origin (the frontend dev server)
CORS_ORIGIN=http://localhost:3000

# Invite-only bootstrap admin (set real values; change before production)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me

# Auth token signing secret (use a strong random value in production)
AUTH_SECRET=please-change-this-to-a-long-random-string
AUTH_TOKEN_TTL=7d

# Optional: enable cross-instance realtime fanout (horizontal scale). Unset =
# single-node in-memory.
# REDIS_URL=redis://localhost:6379

# API rate limit (per bearer token, else per IP)
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=300
