// Prisma schema — https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  MEMBER
  VIEWER
  CLIENT
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  role         UserRole @default(MEMBER)
  // bcrypt hash; null until the account is given a password (invite-provisioned).
  passwordHash String?
  // Profile fields (self-service, edited via PATCH /auth/me). All default to
  // empty so existing rows and the bootstrap admin work without backfill.
  title        String   @default("")
  bio          String   @default("")
  skills       String[] @default([])
  location     String   @default("")
  timezone     String   @default("")
  githubUrl    String   @default("")
  websiteUrl   String   @default("")
  linkedinUrl  String   @default("")
  // Appearance preferences (see Settings → Appearance).
  theme        AppTheme   @default(light)
  density      AppDensity @default(comfortable)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("users")
}

/**
 * A long-lived Personal Access Token that lets a coding agent (e.g. Claude Code
 * via the MCP server) act AS the token's owner. Only the sha-256 hash is stored;
 * the plaintext `cnsofts_pat_…` value is shown once at creation.
 *
 * `userId` is the principal id — a `User.id` (cuid) or the `'admin'` bootstrap
 * sentinel — and is intentionally NOT a foreign key so the env-provisioned admin
 * (which has no users row) can also mint tokens. Verification reconstructs the
 * principal's role live (from `users`, or the env admin), so role changes/
 * deletions take effect immediately.
 */
model ApiToken {
  id         String    @id @default(cuid())
  userId     String
  name       String
  tokenHash  String    @unique
  // Access level: "full" (read + write) or "read_only" (safe/GET methods only).
  scope      String    @default("full")
  // When non-empty, the token may only act on these project ids; empty = all
  // projects the owner can access.
  projectIds String[]  @default([])
  // Opt-in destructive access: without this, the token may not DELETE anything.
  canDelete  Boolean   @default(false)
  // Best-effort count of authenticated requests made with this token.
  usageCount Int       @default(0)
  lastUsedAt DateTime?
  expiresAt  DateTime?
  revokedAt  DateTime?
  createdAt  DateTime  @default(now())

  @@index([userId])
  @@map("api_tokens")
}

// Enum values match the shared Zod contract (@cnsofts/shared) exactly.
enum ProjectStatus {
  planning
  active
  on_hold
  completed
}

enum MemberRole {
  admin
  manager
  member
  viewer
}

// The role an invitation grants on acceptance. Mirrors MemberRole but also
// allows `client`, which places the invitee on the project's client roster
// (ProjectClient) instead of the member roster.
enum InvitationRole {
  admin
  manager
  member
  viewer
  client
}

// Per-user appearance preferences (self-service, edited via PATCH /auth/me).
enum AppTheme {
  light
  dark
}

enum AppDensity {
  comfortable
  compact
}

enum TaskStatus {
  todo
  in_progress
  in_review
  done
}

enum TaskPriority {
  low
  medium
  high
}

model Project {
  id          String          @id @default(cuid())
  name        String
  description String          @default("")
  status      ProjectStatus   @default(planning)
  // Date-only values entered by users; stored as ISO date strings to match the
  // shared contract and the frontend date inputs.
  startDate   String?
  dueDate     String?
  clients     ProjectClient[]
  members     ProjectMember[]
  features    Feature[]
  tasks       Task[]
  milestones  Milestone[]
  channels    Channel[]
  docs        Doc[]
  images      Image[]
  invitations Invitation[]
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@map("projects")
}

model ProjectClient {
  id        String   @id @default(cuid())
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId String
  name      String
  email     String
  company   String?
  createdAt DateTime @default(now())

  @@index([email])
  @@index([projectId, email])
  @@map("project_clients")
}

model ProjectMember {
  id        String     @id @default(cuid())
  project   Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId String
  name      String
  email     String
  role      MemberRole @default(member)
  taskAssignments    TaskAssignee[]
  featureOwnerships  FeatureOwner[]
  createdAt DateTime   @default(now())

  @@index([email])
  @@index([projectId, email])
  @@map("project_members")
}

model Task {
  id          String         @id @default(cuid())
  project     Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId   String
  title       String
  description String         @default("")
  status      TaskStatus     @default(todo)
  priority    TaskPriority   @default(medium)
  // Multiple members can work one task (join rows; see TaskAssignee).
  assignees   TaskAssignee[]
  // Parent feature (optional). SetNull so deleting a feature un-assigns, never
  // deletes, its tasks.
  feature     Feature?       @relation(fields: [featureId], references: [id], onDelete: SetNull)
  featureId   String?
  dueDate     String?
  // Manual ordering within a status column (drag-to-reorder). Lower = higher up.
  position    Int            @default(0)
  subtasks    Subtask[]
  events      TaskEvent[]
  sharedInMessages Message[] @relation("MessageTask")
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([projectId])
  @@index([featureId])
  @@map("tasks")
}

// Task ↔ member assignment (many-to-many join row).
model TaskAssignee {
  id        String        @id @default(cuid())
  task      Task          @relation(fields: [taskId], references: [id], onDelete: Cascade)
  taskId    String
  member    ProjectMember @relation(fields: [memberId], references: [id], onDelete: Cascade)
  memberId  String
  createdAt DateTime      @default(now())

  @@unique([taskId, memberId])
  @@index([memberId])
  @@map("task_assignees")
}

model Subtask {
  id        String   @id @default(cuid())
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  taskId    String
  title     String
  done      Boolean  @default(false)
  position  Int      @default(0)
  createdAt DateTime @default(now())

  @@index([taskId])
  @@map("subtasks")
}

enum TaskEventKind {
  comment
  activity
}

model TaskEvent {
  id        String        @id @default(cuid())
  task      Task          @relation(fields: [taskId], references: [id], onDelete: Cascade)
  taskId    String
  kind      TaskEventKind @default(comment)
  author    String
  // Name of the coding agent (PAT) that performed this, when done via an agent.
  agentName String?
  body      String
  createdAt DateTime      @default(now())

  @@index([taskId, createdAt])
  @@map("task_events")
}


// Enum values match the shared Zod contract (milestoneStatusSchema) exactly.
enum MilestoneStatus {
  upcoming
  in_progress
  done
}

// A checkpoint on the project roadmap — a client-facing deadline marker that
// tracks what is delivered and when. Ordered manually via `position`.
model Milestone {
  id          String          @id @default(cuid())
  project     Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId   String
  title       String
  description String          @default("")
  dueDate     String?
  status      MilestoneStatus @default(upcoming)
  // Manual ordering in the roadmap (lower = higher up).
  position    Int             @default(0)
  // Set when the checkpoint moves to `done`; cleared if it moves back.
  completedAt DateTime?
  sharedInMessages Message[]  @relation("MessageMilestone")
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@index([projectId])
  @@map("milestones")
}

// A unit of work that groups tasks (the parent of Tasks). Enum values match the
// shared Zod contract (@cnsofts/shared) exactly.
enum FeatureStatus {
  planned
  active
  shipped
}

model Feature {
  id          String         @id @default(cuid())
  project     Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId   String
  name        String
  description String         @default("")
  status      FeatureStatus  @default(planned)
  // Multiple members can own/drive one feature (join rows; see FeatureOwner).
  owners      FeatureOwner[]
  // Date-only value (ISO date string), matching Task.dueDate / Project.dueDate.
  targetDate  String?
  // Pinned features float to the top of the board, ahead of `position` order.
  pinned      Boolean        @default(false)
  // Swimlane ordering (drag-to-reorder). Lower = higher up.
  position    Int            @default(0)
  tasks       Task[]
  sharedInMessages Message[] @relation("MessageFeature")
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([projectId])
  @@map("features")
}

// Feature ↔ member ownership (many-to-many join row).
model FeatureOwner {
  id        String        @id @default(cuid())
  feature   Feature       @relation(fields: [featureId], references: [id], onDelete: Cascade)
  featureId String
  member    ProjectMember @relation(fields: [memberId], references: [id], onDelete: Cascade)
  memberId  String
  createdAt DateTime      @default(now())

  @@unique([featureId, memberId])
  @@index([memberId])
  @@map("feature_owners")
}

// A project discussion channel. Enum values match the shared Zod contract.
enum ChannelVisibility {
  internal
  client
}

model Channel {
  id          String            @id @default(cuid())
  project     Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId   String
  name        String
  description String            @default("")
  visibility  ChannelVisibility @default(internal)
  messages    Message[]
  scheduled   ScheduledMessage[]
  members     ChannelMember[]
  createdAt   DateTime          @default(now())
  // Set when someone marks the conversation answered; the agent's wait loop
  // treats a resolve newer than its last message as "stop, they're satisfied".
  resolvedAt  DateTime?
  resolvedBy  String?

  @@index([projectId])
  @@map("channels")
}

// A message queued to post later. A backend poller claims due rows atomically
// and sends them via the normal post path. Attachment ids are plain (no FK):
// validated at send time.
model ScheduledMessage {
  id                String   @id @default(cuid())
  channel           Channel  @relation(fields: [channelId], references: [id], onDelete: Cascade)
  channelId         String
  author            String
  authorEmail       String?
  agentName         String?
  body              String
  attachedTaskId    String?
  attachedFeatureId String?
  attachedMilestoneId String?
  scheduledFor      DateTime
  // pending | sending | sent | canceled | failed
  status            String   @default("pending")
  sentMessageId     String?
  createdAt         DateTime @default(now())

  @@index([status, scheduledFor])
  @@index([channelId])
  @@map("scheduled_messages")
}

model Message {
  id          String   @id @default(cuid())
  channel     Channel  @relation(fields: [channelId], references: [id], onDelete: Cascade)
  channelId   String
  author      String
  // Stable author identity (login email) for "delete own message"; null on
  // messages that predate this column.
  authorEmail String?
  // Name of the coding agent (PAT) that posted this, when posted via an agent.
  agentName   String?
  body        String
  // Optional shared task/feature (at most one set). SetNull so deleting the
  // target keeps the message; the card renders a "no longer available" state.
  attachedTask      Task?    @relation("MessageTask", fields: [attachedTaskId], references: [id], onDelete: SetNull)
  attachedTaskId    String?
  attachedFeature   Feature? @relation("MessageFeature", fields: [attachedFeatureId], references: [id], onDelete: SetNull)
  attachedFeatureId String?
  attachedMilestone   Milestone? @relation("MessageMilestone", fields: [attachedMilestoneId], references: [id], onDelete: SetNull)
  attachedMilestoneId String?
  createdAt   DateTime @default(now())

  @@index([channelId, createdAt])
  @@map("messages")
}

// Explicit per-channel membership. Access to a channel is granted by a row
// here (matched on the login email); admins bypass it. `name` is for display.
model ChannelMember {
  id        String   @id @default(cuid())
  channel   Channel  @relation(fields: [channelId], references: [id], onDelete: Cascade)
  channelId String
  email     String
  name      String
  createdAt DateTime @default(now())

  @@unique([channelId, email])
  @@index([email])
  @@map("channel_members")
}

// A project documentation page — long-form markdown the team and coding agents
// write to keep everyone aware of what's going on. Bodies can be large, so the
// list endpoint returns metadata only; the body is fetched per doc.
model Doc {
  id             String   @id @default(cuid())
  project        Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId      String
  title          String
  body           String   @default("")
  // Manual ordering in the docs sidebar (lower = higher up).
  position       Int      @default(0)
  // Authorship (mirrors Message): display name + stable login email; agentName
  // is set when a coding agent (PAT) authored/edited the page.
  author         String
  authorEmail    String?
  updatedBy      String?
  updatedByEmail String?
  agentName      String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([projectId])
  @@map("docs")
}

// An uploaded image (doc screenshot, etc.). The bytes live in object storage
// (MinIO/S3) under `key`; this row is the DB-backed metadata + project scope.
// Served publicly by unguessable id via GET /api/images/:id.
model Image {
  id              String   @id @default(cuid())
  project         Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId       String
  key             String   @unique
  mimeType        String
  size            Int
  // Authorship (mirrors Doc): who uploaded it; agentName set when via a PAT.
  uploadedBy      String
  uploadedByEmail String?
  agentName       String?
  createdAt       DateTime @default(now())

  @@index([projectId])
  @@map("images")
}

// A pending invitation of an email to a project (with a role). Created by a
// manager/admin; may predate the invitee's account ("pre-made"). On signup /
// login the invitee sees their pending invitations and accepts → a
// ProjectMember row is created. One row per (project, email); re-inviting a
// declined/canceled email just flips it back to pending.
model Invitation {
  id             String     @id @default(cuid())
  project        Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId      String
  email          String
  role           InvitationRole @default(member)
  // Display name + email of the inviter (for "invited by" in the UI).
  invitedBy      String
  invitedByEmail String?
  // pending | accepted | declined | canceled
  status         String     @default("pending")
  createdAt      DateTime   @default(now())
  respondedAt    DateTime?

  @@unique([projectId, email])
  @@index([email, status])
  @@map("invitations")
}

// Enum values match the shared Zod contract (notificationKindSchema) exactly.
enum NotificationKind {
  task_created
  task_completed
  comment_added
  message_posted
  member_added
  system
}

// An in-app notification for a recipient. `userId` is the AuthUser id (the
// bootstrap admin isn't a `users` row yet, so this is a plain string, not a
// relation). `projectId` is an optional deep-link target.
model Notification {
  id        String           @id @default(cuid())
  userId    String
  kind      NotificationKind
  title     String
  body      String           @default("")
  projectId String?
  // Relative app path to open on click (e.g. /projects/<id>?tab=discussion).
  link      String?
  read      Boolean          @default(false)
  createdAt DateTime         @default(now())

  @@index([userId, read])
  @@index([userId, createdAt])
  @@map("notifications")
}

// A recipient's per-kind delivery preference. Absence means "enabled" (the
// default), so muting is opt-in and existing users need no backfill. `userId`
// is the AuthUser id, mirroring Notification (the env admin has no users row).
model NotificationPreference {
  id      String           @id @default(cuid())
  userId  String
  kind    NotificationKind
  enabled Boolean          @default(true)

  @@unique([userId, kind])
  @@map("notification_preferences")
}
