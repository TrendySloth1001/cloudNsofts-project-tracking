// Prisma schema — https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  MEMBER
  VIEWER
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  role      UserRole @default(MEMBER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

// Enum values match the shared Zod contract (@cnsofts/shared) exactly.
enum ProjectStatus {
  planning
  active
  on_hold
  completed
}

enum MemberRole {
  manager
  member
  viewer
}

enum TaskStatus {
  todo
  in_progress
  in_review
  done
}

enum TaskPriority {
  low
  medium
  high
}

model Project {
  id          String          @id @default(cuid())
  name        String
  description String          @default("")
  status      ProjectStatus   @default(planning)
  // Date-only values entered by users; stored as ISO date strings to match the
  // shared contract and the frontend date inputs.
  startDate   String?
  dueDate     String?
  clients     ProjectClient[]
  members     ProjectMember[]
  tasks       Task[]
  milestones  Milestone[]
  channels    Channel[]
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@map("projects")
}

model ProjectClient {
  id        String   @id @default(cuid())
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId String
  name      String
  email     String
  company   String?
  createdAt DateTime @default(now())

  @@map("project_clients")
}

model ProjectMember {
  id        String     @id @default(cuid())
  project   Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId String
  name      String
  email     String
  role      MemberRole @default(member)
  tasks     Task[]
  createdAt DateTime   @default(now())

  @@map("project_members")
}

model Task {
  id          String         @id @default(cuid())
  project     Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId   String
  title       String
  description String         @default("")
  status      TaskStatus     @default(todo)
  priority    TaskPriority   @default(medium)
  assignee    ProjectMember? @relation(fields: [assigneeId], references: [id], onDelete: SetNull)
  assigneeId  String?
  dueDate     String?
  // Manual ordering within a status column (drag-to-reorder). Lower = higher up.
  position    Int            @default(0)
  subtasks    Subtask[]
  events      TaskEvent[]
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@map("tasks")
}

model Subtask {
  id        String   @id @default(cuid())
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  taskId    String
  title     String
  done      Boolean  @default(false)
  position  Int      @default(0)
  createdAt DateTime @default(now())

  @@map("subtasks")
}

enum TaskEventKind {
  comment
  activity
}

model TaskEvent {
  id        String        @id @default(cuid())
  task      Task          @relation(fields: [taskId], references: [id], onDelete: Cascade)
  taskId    String
  kind      TaskEventKind @default(comment)
  author    String
  body      String
  createdAt DateTime      @default(now())

  @@map("task_events")
}


model Milestone {
  id        String   @id @default(cuid())
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId String
  title     String
  dueDate   String?
  done      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@map("milestones")
}

// A project discussion channel. Enum values match the shared Zod contract.
enum ChannelVisibility {
  internal
  client
}

model Channel {
  id          String            @id @default(cuid())
  project     Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId   String
  name        String
  description String            @default("")
  visibility  ChannelVisibility @default(internal)
  messages    Message[]
  createdAt   DateTime          @default(now())

  @@map("channels")
}

model Message {
  id        String   @id @default(cuid())
  channel   Channel  @relation(fields: [channelId], references: [id], onDelete: Cascade)
  channelId String
  author    String
  body      String
  createdAt DateTime @default(now())

  @@map("messages")
}

// Enum values match the shared Zod contract (notificationKindSchema) exactly.
enum NotificationKind {
  task_created
  task_completed
  comment_added
  message_posted
  member_added
  system
}

// An in-app notification for a recipient. `userId` is the AuthUser id (the
// bootstrap admin isn't a `users` row yet, so this is a plain string, not a
// relation). `projectId` is an optional deep-link target.
model Notification {
  id        String           @id @default(cuid())
  userId    String
  kind      NotificationKind
  title     String
  body      String           @default("")
  projectId String?
  read      Boolean          @default(false)
  createdAt DateTime         @default(now())

  @@index([userId, read])
  @@index([userId, createdAt])
  @@map("notifications")
}
